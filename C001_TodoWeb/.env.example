# Frontend encryption key (required)
VITE_ENCRYPTION_KEY=your-strong-encryption-key

# Lock screen password
# Frontend/dev fallback:
VITE_LOCK_SCREEN_PASSWORD=bj8964
# Server-side validation (recommended, higher priority in production):
LOCK_SCREEN_PASSWORD=bj8964

# Lock screen session signing secret (recommended)
LOCK_SCREEN_SESSION_SECRET=replace-with-long-random-secret

# Local Linux HTTPS for Vite dev server
VITE_DEV_HTTPS_KEY=certs/dev-key.pem
VITE_DEV_HTTPS_CERT=certs/dev-cert.pem

# GitHub sync for Todo API (required in Vercel)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Your new remote repo, e.g. username/ToDo
GITHUB_REPO=your-github-username/ToDo
